# Copy this file to `.env` (in the same directory) and fill in every value.
# Both the dashboard (Vite) and the api-server (run-api-server.bash) read
# from this single .env file.

# ---------------------------------------------------------------------------
# Dashboard (read by Vite at build/dev time, exposed to the browser)
# ---------------------------------------------------------------------------
# Find both at: https://supabase.com/dashboard/project/<ref>/settings/api
#   - "Project URL"               -> VITE_SUPABASE_URL
#   - "Project API keys" -> "anon" / "public" (NOT service_role)  -> VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# api-server (read by run-api-server.bash, server-side only)
# ---------------------------------------------------------------------------
# SUPABASE_PROJECT_URL: same value as VITE_SUPABASE_URL above.
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co

# Legacy HS256 fallback — leave both lines commented out for normal
# Supabase projects. Only uncomment if your project still uses an HS256
# shared secret AND you want to skip JWKS verification.
#SUPABASE_LEGACY_HS256=1
#SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: also use Supabase Postgres as the api-server's DB.
# Leave commented to keep using local sqlite.
# Find at: Settings -> Database -> Connection string (use the "Session" pooler URL).
#SUPABASE_DB_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
