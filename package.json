{
  "name": "root",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.0.0",
    "npm": ">=99"
  },
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.3.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "pyright": "1.1.409",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,scss}": [
      "prettier --write"
    ],
    "**/*.py": [
      ".venv/bin/pipenv run isort",
      ".venv/bin/pipenv run black"
    ]
  },
  "pnpm": {
    "overrides": {
      "typescript-json-schema>@types/node": "*",
      "form-data@<4.0.4": "^4.0.4",
      "axios@<1.12.0": "^1.16.0",
      "qs": "^6.14.2",
      "min-document": "^2.19.1",
      "follow-redirects": "^1.16.0",
      "lodash": "^4.18.0",
      "yaml": "^1.10.3",
      "serialize-javascript": "^7.0.5",
      "react-router": "^6.30.2",
      "@babel/runtime": "^7.26.10",
      "file-type": "^21.3.1",
      "@remix-run/router": "^1.23.2",
      "rollup": "^4.59.0",
      "phin": "^3.7.1",
      "node-fetch": "^2.6.7",
      "ws": "^7.5.10",
      "cross-spawn": "^7.0.5",
      "tar-fs": "^2.1.4"
    }
  },
  "overrides": {
    "react-error-overlay": "6.0.9"
  }
}
